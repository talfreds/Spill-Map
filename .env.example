FIREBASE_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abc123def456
FIREBASE_MEASUREMENT_ID=G-ABCDEFG123

# API key for google Maps SDK for Android, Maps SDK for iOS, Maps JavaScript API (required for the web preview), Places API (required for search)
GOOGLE_API_KEY=your-google-maps-platform-api-key

# Optional: Firebase test user credentials (for development only)
FIREBASE_TEST_EMAIL=tester@example.com
FIREBASE_TEST_PASSWORD=change-me

# Backend Firebase Admin credentials (service account JSON path)
# Keep the key at repo root for a single secrets location.
FIREBASE_SERVICE_ACCOUNT_PATH=/workspaces/Spill-Map/firebase-service-account.json

# OCI Object Storage (S3-compatible) for spill image uploads
# Create a Customer Secret Key in OCI and set these values.
OCI_OBJECT_STORAGE_NAMESPACE=your-oci-namespace
OCI_OBJECT_STORAGE_BUCKET=spill-images
OCI_OBJECT_STORAGE_REGION=us-ashburn-1
OCI_OBJECT_STORAGE_ACCESS_KEY=your-customer-secret-key-access-id
OCI_OBJECT_STORAGE_SECRET_KEY=your-customer-secret-key-secret

# Optional: Override image URL base if using custom domain/CDN.
# By default backend returns: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com/<bucket>/<object_key>
# OCI_OBJECT_STORAGE_PUBLIC_BASE_URL=https://objectstorage.us-ashburn-1.oraclecloud.com/n/your-oci-namespace/b/spill-images/o

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================
# DEVELOPMENT:
# - Codespaces: Auto-detected (https://<name>-8000.app.github.dev)
# - Local: Auto-detected (http://localhost:8000)
# - No configuration needed below!
#
# PRODUCTION:
# - Set BACKEND_BASE_URL to your production backend URL
# - Example: BACKEND_BASE_URL=https://api.example.com

# BACKEND_BASE_URL=https://api.example.com

# ============================================================================
# CORS CONFIGURATION (Backend only)
# ============================================================================
# DEVELOPMENT:
# - Auto-detected: localhost and *.app.github.dev
# - No configuration needed below!
#
# PRODUCTION:
# - Set ALLOWED_ORIGINS to comma-separated list of allowed origins
# - Example: ALLOWED_ORIGINS=https://spill-map.example.com,https://www.spill-map.example.com

# ALLOWED_ORIGINS=https://spill-map.example.com,https://www.spill-map.example.com

