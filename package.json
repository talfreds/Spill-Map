{
  "name": "spill-map",
  "version": "1.0.0",
  "description": "PinChat Firebase authentication bootstrap",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "validate:auth": "node --env-file-if-exists=.env scripts/validate-auth.js",
    "flutter:install": "bash scripts/install-flutter.sh",
    "flutter:web:prepare-env": "node --env-file-if-exists=.env scripts/prepare-flutter-web-env.js",
    "flutter:pub:get": "cd spill_flutter && ../.tooling/flutter/bin/flutter pub get",
    "flutter:web:run": "bash scripts/flutter-web-run.sh",
    "flutter:test": "cd spill_flutter && ../.tooling/flutter/bin/flutter test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talfreds/Spill-Map.git"
  },
  "keywords": [
    "firebase",
    "authentication",
    "pinchat"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/talfreds/Spill-Map/issues"
  },
  "homepage": "https://github.com/talfreds/Spill-Map#readme",
  "dependencies": {
    "firebase": "^12.14.0"
  }
}
